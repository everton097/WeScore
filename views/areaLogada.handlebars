<section>
	<div class="area-logada">
		<div class="mural-al">
			<div class="time-al">
				<img class="logotime-al" src="/img/PDB.png" alt="logotime1" />
				<p class="nometime-al">Matheus Pontarolo</p>
			</div>
			<div class="menu-al">
				<ul>
					<li><a href="/">Cadastro</a></li>
					<li><a href="/">Times</a></li>
					<li><a href="/">Campeonatos</a></li>
				</ul>
			</div>
		</div>
		<div class="cadastro">
			<h1>Cadastro de Jogador</h1>
			<form action="/adicionar" method="POST">
				<div class="form-control">
					<label for="nome">Nome:</label>
					<input type="text" id="nome" name="nome" placeholder="Digite seu nome" >
				</div>
				<div class="form-control">
					<label for="sobrenome">Sobrenome:</label>
					<input type="text" id="sobrenome" name="sobrenome" required><br><br>
				</div>
				<div class="form-control">
					<label for="cpf">CPF:</label>
					<input type="text" id="cpf" name="cpf" required><br><br>
				</div>
				<div class="form-control">
					<label for="telefone">Telefone:</label>
					<input type="text" id="telefone" name="telefone" required><br><br>
				</div>
				<div class="form-control">
					<label for="numero_camisa">Número da Camisa:</label>
					<input type="number" id="numero_camisa" name="numero_camisa" required><br><br>
				</div>
				<div class="form-control-button">
					<input type="submit" class="form-button" value="Cadastrar">
				</div>
			</form>
		</div>
		<div class="cadastro">
			<h1>Cadastro de Time</h1>
			<form action="/adicionar" method="POST">
				<div class="form-control">
					<label for="nome">Nome:</label>
					<input type="text" id="nome" name="nome" required><br><br>
				</div>
				<div class="form-control">
					<label for="cidade">Cidade:</label>
					<input type="text" id="cidade" name="cidade" required><br><br>
				</div>
				<div class="form-control">
					<label for="imagem_time">Escudo (JPEG ou PNG):</label>
					<input type="file" id="imagem_time" name="imagem_time" accept="image/jpeg, image/png, image/gif"
						required><br><br>
				</div>
				<div class="form-control-button">
					<input type="submit" class="form-button" value="Cadastrar">
				</div>
			</form>
		</div>
	</div>
</section>