nome jogador
sobrenome
cpf
telefone
numeroCamiseta
-->
<section class="tamanho-tela">
	<div class="area-logada">
		<div class="muralCad-al">
			<div class="menuCad-al">
				<ul>
					<li><a href="/cadastroTime">Cadastro de times</a></li>
					<li><a href="/cadastroJogadores">Cadastro de jogadores</a></li>
					<li><a href="/cadastroCamp">Cadastro de Campeonatos</a></li>
				</ul>
			</div>
		</div>
        <div class="cadastro-responsavel">
			<h1>Cadastro de Jogadores</h1>
			<form action="/adicionar" method="POST">
				<div class="half-box">
					<label for="nome">Nome:</label>
					<input type="text" id="nome" name="nome" placeholder="Digite seu nome" >
				</div>
				<div class="half-box">
					<label for="sobrenome">Sobrenome:</label>
					<input type="text" id="sobrenome" name="sobrenome" placeholder="Digite seu Sobrenome" required>
				</div>
				<div class="half-box">
					<label for="cpf">CPF:</label>
					<input type="text" id="cpf" name="cpf" placeholder="000.000.000-00" maxlength="14" pattern="\d{3}\.\d{3}\.\d{3}-\d{2}" title="Digite um CPF válido (exemplo: 123.456.789-09)" required>
				</div>
				<div class="half-box">
                    <label for="telefone">Telefone:</label>
                    <input type="tel" id="telefone" name="telefone" inputmode="tel" pattern="[0-9]{2}[0-9]{4,5}[0-9]{4}" placeholder="(00) 00000-0000" maxlength="11" required>
                </div>
                <div class="half-box">
					<label for="numero_camisa">Número da Camisa:</label>
					<input type="number" id="numero_camisa" name="numero_camisa" min="0" max="99" placeholder="00" required>
				</div>
                <div class="half-box" class="form-button">
					<label for="times">Escolha um Time:</label>
					<select id="times">
						<option value="">Escolher Time</option>
						<option value="Time1">Time 1</option>
						<option value="Time2">Time 2</option>
						<option value="Time3">Time 3</option>
						<!-- Adicione mais opções de times aqui a partir do banco de dados -->
					</select>
				</div>
            </form>
            <div class="form-control-button button-center">
				<button onclick="cadastrarNoTime()" class="form-button">Cadastrar</button>
			</div>
		</div>
	</div>

	<div class="modal" id="modal">
        <div class="modal-content">
            <span class="close" onclick="fecharModal()">&times;</span>
            <p id="mensagem"></p>
        </div>
    </div>

    <script>
        var usuarioCadastrado = false;

        function cadastrarNoTime() {
            if (usuarioCadastrado) {
                exibirMensagem("Você já está cadastrado em um time.");
            } else {
                var selectTimes = document.getElementById('times');
                var selectedTime = selectTimes.value;

                if (selectedTime) {
                    usuarioCadastrado = true;
                    exibirMensagem("Você está cadastrado no time: " + selectedTime);
                } else {
                    exibirMensagem("Você não está cadastrado em nenhum time.");
                }
            }
        }

        function exibirMensagem(mensagem) {
            var modal = document.getElementById('modal');
            var mensagemElement = document.getElementById('mensagem');
            mensagemElement.textContent = mensagem;
            modal.style.display = "block";
        }

        function fecharModal() {
            var modal = document.getElementById('modal');
            modal.style.display = "none";
        }
    </script>

</section>